<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:layout_marginStart="15dp"
    android:layout_marginEnd="15dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="15dp"
        android:paddingBottom="24dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="260dp"
            app:cardCornerRadius="16dp">

            <ImageView
                android:id="@+id/breed_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/breed_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/kcc_ganpan"
            android:textColor="@color/basic"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/breed_name_english"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/hakgyoansimwooju"
            android:textColor="@color/btn_gray"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/breed_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/hakgyoansimwooju"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/basic"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="@color/underline" />

        <TextView
            android:id="@+id/description_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/kcc_ganpan"
            android:text="Breed Overview"
            android:textColor="@color/basic"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/breed_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/hakgyoansimwooju"
            android:lineSpacingExtra="5dp"
            android:textColor="@color/basic"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/history_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/kcc_ganpan"
            android:text="History"
            android:textColor="@color/basic"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/breed_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/hakgyoansimwooju"
            android:lineSpacingExtra="5dp"
            android:textColor="@color/basic"
            android:textSize="15sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
