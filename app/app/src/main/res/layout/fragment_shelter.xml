<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/shelter_notice_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/kcc_ganpan"
        android:text="보호소 지도 안내"
        android:textColor="@color/basic"
        android:textSize="26sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/shelter_notice_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/hakgyoansimwooju"
        android:lineSpacingExtra="4dp"
        android:text="현재 보호소 지도 기능은 외부 지도 인증 이슈로 인해 임시 비활성화되어 있습니다."
        android:textColor="@color/basic"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shelter_notice_title" />

    <LinearLayout
        android:id="@+id/shelter_notice_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/background_edittext"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shelter_notice_subtitle">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/kcc_ganpan"
            android:text="현재 상태"
            android:textColor="@color/basic"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/hakgyoansimwooju"
            android:lineSpacingExtra="6dp"
            android:text="- 카카오맵 인증 키를 확인할 수 없어 지도를 표시하지 않습니다.&#10;- 검은 화면 대신 안내 화면으로 대체해 앱 사용 흐름이 끊기지 않도록 처리했습니다.&#10;- 지도 기능은 키 권한이 확보되면 다시 연결할 수 있습니다."
            android:textColor="@color/basic"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/shelter_notice_qa_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/background_edittext"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shelter_notice_card">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/kcc_ganpan"
            android:text="QA 관점 처리"
            android:textColor="@color/basic"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/hakgyoansimwooju"
            android:lineSpacingExtra="6dp"
            android:text="외부 인증 의존성으로 해결할 수 없는 기능은 원인을 명확히 분리하고, 대체 UI를 제공해 나머지 핵심 기능 검증이 가능하도록 유지했습니다."
            android:textColor="@color/basic"
            android:textSize="15sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/shelter_notice_footer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/hakgyoansimwooju"
        android:lineSpacingExtra="4dp"
        android:text="복구 조건: 카카오 개발자 콘솔에서 현재 앱 패키지와 키 권한이 확인되면 지도 기능을 재연결할 수 있습니다."
        android:textColor="@color/underline"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shelter_notice_qa_card" />

</androidx.constraintlayout.widget.ConstraintLayout>
